      posthog.init('phc_kHZWuiUzdGkjQ7OvXfER2jygjMyTK9oyFfjVeg5vuAg', {
        api_host: 'https://us.i.posthog.com',
        defaults: '2025-11-30',
        person_profiles: 'identified_only',
      })
    </script>
  </head>

  <body class="bg-background text-foreground min-h-screen">
    <Navbar client:load />
    <main class="pt-24">
      <section class="relative isolate overflow-hidden min-h-[52vh] md:min-h-[60vh]" data-carousel-root>
        <div class="absolute inset-0" data-carousel-slides>
          {carouselImages.map((image, index) => (
            <div
              class={`absolute inset-0 transition-opacity duration-1000 ${index === 0 ? 'opacity-100' : 'opacity-0'}`}
              data-carousel-slide
            >
              <div class="h-full w-full flex items-center justify-center p-4 md:p-8 bg-black/20">
                <img
                  src={image}
                  alt={`${title} preview ${index + 1}`}
                  class="h-full w-full object-contain"
                  loading={index === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                />
              </div>
            </div>
          ))}
        </div>
        <button
          type="button"
          class="absolute left-3 md:left-6 top-1/2 -translate-y-1/2 z-20 h-10 w-10 md:h-12 md:w-12 rounded-full border border-white/35 bg-black/40 text-white backdrop-blur-sm hover:bg-black/55 transition"
          data-carousel-prev
          aria-label="Previous slide"
        >
          <span aria-hidden="true" class="text-xl leading-none">&larr;</span>
        </button>
        <button
          type="button"
          class="absolute right-3 md:right-6 top-1/2 -translate-y-1/2 z-20 h-10 w-10 md:h-12 md:w-12 rounded-full border border-white/35 bg-black/40 text-white backdrop-blur-sm hover:bg-black/55 transition"
          data-carousel-next
          aria-label="Next slide"
        >
          <span aria-hidden="true" class="text-xl leading-none">&rarr;</span>
        </button>
        <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/50 to-black/70" />
        <div class="relative z-10 max-w-6xl mx-auto px-4 min-h-[52vh] md:min-h-[60vh] flex items-center">
          <div class="max-w-2xl text-white">
            <h1 class="text-4xl md:text-6xl font-bold tracking-tight">{title}</h1>
            <p class="mt-4 text-base md:text-xl text-white/90 leading-relaxed">{description}</p>
          </div>
        </div>
        <div class="absolute bottom-6 left-0 right-0 z-10">
          <div class="max-w-6xl mx-auto px-4 flex gap-2" data-carousel-dots>
            {carouselImages.map((_, index) => (
              <button
                type="button"
                class={`h-2.5 rounded-full transition-all ${index === 0 ? 'w-10 bg-white' : 'w-2.5 bg-white/55 hover:bg-white/75'}`}
                data-carousel-dot
                data-carousel-index={index}
                aria-label={`Show slide ${index + 1}`}
              />
            ))}
          </div>
        </div>
      </section>

      <section class="px-4 mt-8 max-w-6xl mx-auto">
        <h2 class="text-2xl font-semibold">Repositories and sites</h2>
        <div class="mt-4 grid gap-4 md:grid-cols-2">
          {projects.map((project) => (
            <article class="rounded-xl border border-border bg-card p-5">
              <h3 class="text-lg font-semibold">{project.name}</h3>
              <div class="mt-3 space-y-1 text-sm">
                <p>
                  Repo:{' '}
                  <a class="text-accent underline hover:text-accent/80" href={project.repo} target="_blank" rel="noopener noreferrer">
                    {project.repo}
                  </a>
                </p>
                <p>
                  Site:{' '}
                  <a class="text-accent underline hover:text-accent/80" href={project.site} target="_blank" rel="noopener noreferrer">
                    {project.site}
                  </a>
                </p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="px-4 py-10 max-w-4xl mx-auto">
        <div class="prose max-w-none" set:html={markdownBody} />
      </section>
    </main>

    <script is:inline>
      (() => {
        const root = document.querySelector('[data-carousel-root]');
        if (!root) return;

        const slides = Array.from(root.querySelectorAll('[data-carousel-slide]'));
        const dots = Array.from(root.querySelectorAll('[data-carousel-dot]'));
        const prevButton = root.querySelector('[data-carousel-prev]');
        const nextButton = root.querySelector('[data-carousel-next]');
        if (slides.length <= 1) return;

        let currentIndex = 0;
        let intervalId;

        const setActiveSlide = (nextIndex) => {
          currentIndex = (nextIndex + slides.length) % slides.length;
          slides.forEach((slide, index) => {
            slide.classList.toggle('opacity-100', index === currentIndex);
            slide.classList.toggle('opacity-0', index !== currentIndex);
          });
          dots.forEach((dot, index) => {
            dot.classList.toggle('w-10', index === currentIndex);
            dot.classList.toggle('bg-white', index === currentIndex);
            dot.classList.toggle('w-2.5', index !== currentIndex);
            dot.classList.toggle('bg-white/55', index !== currentIndex);
          });
        };

        const startRotation = () => {
          if (intervalId) window.clearInterval(intervalId);
          intervalId = window.setInterval(() => {
            setActiveSlide(currentIndex + 1);
          }, 5000);
        };

        dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const index = Number(dot.getAttribute('data-carousel-index'));
            setActiveSlide(index);
            startRotation();
          });
        });

        prevButton?.addEventListener('click', () => {
          setActiveSlide(currentIndex - 1);
          startRotation();
        });

        nextButton?.addEventListener('click', () => {
          setActiveSlide(currentIndex + 1);
          startRotation();
        });

        setActiveSlide(0);
        startRotation();
      })();
    </script>
  </body>
</html>
